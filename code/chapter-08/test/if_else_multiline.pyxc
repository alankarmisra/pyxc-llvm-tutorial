# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed a function definition.
# CHECK: Evaluated to 5.000000


# Tests: if/else with then and else expressions on separate lines.
# conditionalexpr = "if" expression ":" [ eols ] expression [ eols ] "else" ":" [ eols ] expression
# The [ eols ] tokens before 'else' and after 'else:' allow this layout.

def minval(a, b):
return if a < b:
a
else:
b

minval(5, 10)
