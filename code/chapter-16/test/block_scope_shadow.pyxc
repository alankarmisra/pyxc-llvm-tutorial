# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 99.000000
# CHECK: 1.000000
# CHECK-NOT: ready>

# Tests: the shadowed variable is visible inside the block and the outer
# variable is restored after the block exits.

extern def printd(x: float64) -> float64

def f() -> float64:
    var x: float64 = 1.0
    if x > 0:
        var x: float64 = 99.0
        printd(x)
    return x

printd(f())
