extern def putchard(x: float64) -> float64

# Logical not: 0 -> 1, non-zero -> 0.
@unary
def !(v: float64) -> float64:    return if v == 0: 1 else: 0

# Sequencing operator: evaluate lhs for side effects, then return rhs.
@binary(1)
def ;(x: float64, y: float64) -> float64:    return y

# Logical OR (no short-circuit).
@binary(5)
def |(lhs: float64, rhs: float64) -> float64:    return if lhs: 1 else: if rhs: 1 else: 0

# Logical AND (no short-circuit).
@binary(6)
def &(lhs: float64, rhs: float64) -> float64:    return if !lhs: 0 else: !!rhs

# printdensity - map iteration count to an ASCII shade.
def printdensity(d: float64) -> float64:
    return if d > 8: putchard(32.0) else: if d > 4: putchard(46.0) else: if d > 2: putchard(43.0) else: putchard(42.0)

# Determine whether z = z^2 + c diverges for the given point.
def mandelconverger(real: float64, imag: float64, iters: float64, creal: float64, cimag: float64) -> float64:
    return if iters > 255 | (real * real + imag * imag > 4): iters else: mandelconverger(real * real - imag * imag + creal, 2 * real * imag + cimag, iters + 1, creal, cimag)

# Return number of iterations required for escape.
def mandelconverge(real: float64, imag: float64) -> float64:
    return mandelconverger(real, imag, 0, real, imag)

# Render one row.
def mandelrow(xmin: float64, xmax: float64, xstep: float64, y: float64) -> float64:
    return for var x: float64 = xmin, x < xmax, xstep:
               printdensity(mandelconverge(x, y))

# Render full 2D region.
def mandelhelp(xmin: float64, xmax: float64, xstep: float64, ymin: float64, ymax: float64, ystep: float64) -> float64:
    return for var y: float64 = ymin, y < ymax, ystep:
               mandelrow(xmin, xmax, xstep, y) ; putchard(10.0)

# Top-level helper.
def mandel(realstart: float64, imagstart: float64, realmag: float64, imagmag: float64) -> float64:
    return mandelhelp(realstart, realstart + realmag * 78, realmag, imagstart, imagstart + imagmag * 40, imagmag)

mandel(-2.3, -1.3, 0.05, 0.07)
mandel(-2, -1, 0.02, 0.04)
mandel(-0.9, -1.4, 0.02, 0.03)
