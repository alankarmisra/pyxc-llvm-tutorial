# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 55.000000

# Tests: a realistic program — global accumulator, helper function, main calls
# it in a loop and prints the sum 1+2+...+10 = 55.

extern def printd(x: float64) -> float64

var sum: float64 = 0.0

def accumulate(n: float64) -> None:
    sum = sum + n

def main() -> None:
    for var i: float64 = 1, i < 11, 1:
        accumulate(i)
    printd(sum)
