# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 6.000000
# CHECK-NOT: ready>


# Tests: file mode with an indented block and a for loop.

extern def printd(x: float64) -> float64

def sum_to(n: float64) -> float64:
    var acc: float64 = 0.0
    for var i: float64 = 1, i <= n, 1:
        acc = acc + i
    return acc

printd(sum_to(3))
