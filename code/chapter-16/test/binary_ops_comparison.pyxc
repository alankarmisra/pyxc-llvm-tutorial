# Tests: all six builtin binary comparison operators.
# Comparisons return True for true, False for false.
# builtinbinaryop = ... | "<" | "<=" | ">" | ">=" | "==" | "!="

1 < 2

3 <= 3

4 > 3

5 >= 5

2 == 2

2 != 3

# False case: exercises the 0.0 path.
2 < 1

4 <= 3

3 > 4

4 >= 5

1 == 2

3 != 3
