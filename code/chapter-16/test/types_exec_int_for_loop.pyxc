# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 10.000000

# Tests: a for loop with int induction variable computes a correct sum.
# sum(1..4) = 10; the int result is cast to float64 for output.

extern def printd(x: float64) -> float64

def main() -> None:
    var sum: int = 0
    for var i: int = 1, i <= 4, 1:
        sum = sum + i
    printd(float64(sum))
    return
