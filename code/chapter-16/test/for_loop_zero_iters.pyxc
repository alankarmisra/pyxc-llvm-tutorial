# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: 0.000000


# Tests: for loop whose initial condition is false — the body never executes.
# The implicit function return is 0.0 when nothing returns explicitly.
# forexpr = "for" identifier "=" expression "," expression "," expression ":" [ eols ] ( block | statement )

def no_iters(x: float64) -> float64:
    var y: float64 = 0
    for var i: float64 = 1, i < 1, 1:
        y = y + x
    return y

# The loop never executes; the accumulator stays at 0.0.
no_iters(42)
