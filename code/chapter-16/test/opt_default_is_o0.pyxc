# RUN: %pyxc --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: add i{{32|64}}
# CHECK: mul i{{32|64}}
# CHECK: sitofp
# CHECK-NOT: ret double 9.000000e+00

# Tests: without any -O flag, the default optimization level is 0.
# Constant arithmetic is not folded; fadd and fmul instructions remain.

extern def printd(x: float64) -> float64

def main() -> None:
    var a: int = 2 + 1
    var b: int = a * 3
    printd(float64(b))
    return
