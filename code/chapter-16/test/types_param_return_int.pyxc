# RUN: %pyxc --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: define i{{32|64}} @add(i{{32|64}} %a, i{{32|64}} %b)
# CHECK: ret i{{32|64}}

# Tests: typed parameters and return types map to integer IR.

extern def printd(x: float64) -> float64

def add(a: int, b: int) -> int:
    return a + b

def main() -> None:
    printd(float64(add(3, 4)))
    return
