# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK: 2.000000
# CHECK: 3.000000


# Tests: for loop executes its body once per iteration.
# forstmt = "for" identifier "=" expression "," expression "," expression ":" suite ;
#
# count(3) runs: i=1 (printd(1.0)), i=2 (printd(2.0)), i=3 (printd(3.0)), i=4 (4<=3 false, stop).
# The for statement itself returns 0.0.

extern def printd(x: float64) -> float64

def count(n: float64) -> None:
    for var i: float64 = 1, i <= n, 1:
        printd(i)

count(3)
