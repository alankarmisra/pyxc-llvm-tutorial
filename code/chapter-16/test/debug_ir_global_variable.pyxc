# RUN: %pyxc -g --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: !DIGlobalVariableExpression
# CHECK: !DIGlobalVariable(name: "counter"

# Tests: a top-level 'var' declaration produces DIGlobalVariableExpression
# metadata attached to the LLVM GlobalVariable. The variable name is
# preserved as a DIGlobalVariable node.

extern def printd(x: float64) -> float64

var counter: float64 = 0.0

def main() -> None:
    counter = counter + 1
    printd(counter)
