# RUN: not %pyxc %s 2>&1 | FileCheck %s
# CHECK: main() must take no arguments

# Tests: main() is the file-mode entry point and must be zero-argument.
# Defining main with parameters is a runtime error when RunFileMode tries to call it.

extern def printd(x: float64) -> float64

def main(x: float64) -> None:
    printd(x)
