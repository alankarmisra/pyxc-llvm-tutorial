# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK-NOT: ready>

# Tests: variables declared in nested blocks do not leak to outer scopes.
# Each block gets its own x; after all blocks exit, the function-scope x=1
# is restored.

extern def printd(x: float64) -> float64

def f() -> float64:
    var x: float64 = 1.0
    if x > 0:
        var x: float64 = 2.0
        if x > 0:
            var x: float64 = 5.0
    return x

printd(f())
