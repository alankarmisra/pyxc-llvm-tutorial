# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 3.000000

# Tests: float64 → int truncates (3.9 → 3), then int → float64 widens (3 → 3.0).
# The roundtrip float64(int(x)) produces the floor for positive numbers.

extern def printd(x: float64) -> float64

def main() -> None:
    printd(float64(int(3.9)))
    return
