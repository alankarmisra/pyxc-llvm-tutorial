# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK: 2.000000
# CHECK-NOT: ready>

# Tests: forstmt nested inside ifstmt block.
# compoundstmt = ifstmt | forstmt ;
# suite = simplestmt | compoundstmt | eols block ;
# When n > 0, the if block runs the for loop. When n <= 0, nothing is printed.

extern def printd(x: float64) -> float64

def run(n: float64) -> None:
    if n > 0:
        for var i: float64 = 1, i <= n, 1:
            printd(i)

run(2)
run(0)
