# REQUIRES: llvm-dwarfdump
# RUN: %pyxc -g --emit obj -o %t.o %s
# RUN: %dwarfdump %t.o | FileCheck %s
# CHECK: DW_TAG_formal_parameter
# CHECK: DW_AT_name{{.*}}"lhs"
# CHECK: DW_AT_name{{.*}}"rhs"

# Tests: function parameters appear in DWARF as DW_TAG_formal_parameter entries
# with the correct DW_AT_name. The order (lhs, then rhs) matches declaration order.

extern def printd(x: float64) -> float64

def add(lhs: float64, rhs: float64) -> float64:
    return lhs + rhs

def main() -> None:
    printd(add(3, 4))
