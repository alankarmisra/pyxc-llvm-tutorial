# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 120.000000

# Tests: a recursive function works in the emitted executable.
# factorial(5) = 120.

extern def printd(x: float64) -> float64

def factorial(n: float64) -> float64:
    if n < 2:
        return 1.0
    return n * factorial(n - 1)

def main() -> None:
    printd(factorial(5))
