# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: 2.000000


# Tests: a program with multiple top-level forms separated by blank lines.
# program = [ eols ] [ top { eols top } ] [ eols ]
# top     = definition | external | toplevelexpr

extern def printd(x: float64) -> float64

def double_it(x: float64) -> float64: return x + x

double_it(1)
