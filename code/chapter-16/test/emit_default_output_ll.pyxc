# RUN: cd %T && %pyxc --emit llvm-ir %s
# RUN: FileCheck --input-file=%T/out.ll %s
# CHECK: define double @sq

# Tests: when -o is omitted with --emit llvm-ir the output is written to out.ll
# in the current working directory.

extern def printd(x: float64) -> float64

def sq(x: float64) -> float64: return x * x
