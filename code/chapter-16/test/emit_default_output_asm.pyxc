# RUN: cd %T && %pyxc --emit asm %s
# RUN: FileCheck --input-file=%T/out.s %s
# CHECK: .globl
# CHECK: {{_?}}sq

# Tests: when -o is omitted with --emit asm the output is written to out.s
# in the current working directory.

extern def printd(x: float64) -> float64

def sq(x: float64) -> float64: return x * x
