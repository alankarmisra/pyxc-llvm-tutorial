# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK: 2.000000
# CHECK: 3.000000

# Tests: for loop allows optional 'var' before the loop variable.

extern def printd(x: float64) -> float64

def main() -> None:
    for var i: int = 1, i <= 3, 1:
        printd(float64(i))
    return
