# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: A

# Tests: putchard is provided as a built-in by the compiler (no external runtime
# object needed). putchard(65.0) prints ASCII 'A' to stderr.

extern def putchard(x: float64) -> float64

def main() -> None:
    putchard(65.0)
