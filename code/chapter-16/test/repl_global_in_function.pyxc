# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: 10.000000

# Tests: REPL mode — a function defined after a global declaration can read
# the global. Each REPL input compiles into a fresh module; the function
# re-declares the global as extern and the JIT resolves it to the globals module.

extern def printd(x: float64) -> float64
var x: float64 = 10.0
def get_x() -> float64: return x
printd(get_x())
