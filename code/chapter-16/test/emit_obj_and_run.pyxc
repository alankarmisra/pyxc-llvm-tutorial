# RUN: %pyxc --emit obj -o %t.o %s
# RUN: %clang %t.o %runtime_c -o %t.exe
# RUN: %t.exe 2>&1 | FileCheck %s
# CHECK: 9.000000

# Tests: --emit obj produces a native object file that can be linked with clang
# and executed.  The emitted binary must produce the same observable output as
# JIT mode would (printd writes to stderr).

extern def printd(x: float64) -> float64

def sq(x: float64) -> float64: return x * x

def main() -> None:
    printd(sq(3))
