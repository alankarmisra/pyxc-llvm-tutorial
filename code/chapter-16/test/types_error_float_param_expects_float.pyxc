# RUN: not %pyxc --emit llvm-ir -o %t.ll %s 2>&1 | FileCheck %s
# CHECK: expects float

# Tests: diagnostics preserve the 'float' spelling when a float parameter is
# expected and a non-numeric type is passed.

def takes_float(x: float) -> None:
    return

def main() -> None:
    var y: bool = True
    takes_float(y)
    return
