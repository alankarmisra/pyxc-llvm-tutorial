# RUN: %pyxc --emit exe -o %t %s
# RUN: test -x %t
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 9.000000

# Tests: --emit exe -o <path> compiles and links in one step, producing an
# executable at the exact output path. printd is provided by the compiler
# (no external runtime.c required).

extern def printd(x: float64) -> float64

def sq(x: float64) -> float64: return x * x

def main() -> None:
    printd(sq(3))
