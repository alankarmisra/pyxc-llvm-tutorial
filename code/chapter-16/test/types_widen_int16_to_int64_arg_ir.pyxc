# RUN: %pyxc --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: sext i16
# CHECK: call i64 @f(i64

# Tests: passing int16 to a function that expects int64 widens the argument.

def f(x: int64) -> int64:
    return x

def main() -> None:
    var n: int16 = int16(5)
    f(n)
    return
