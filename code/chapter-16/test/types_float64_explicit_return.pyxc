# RUN: %pyxc --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: define double @scale(double %x)
# CHECK: ret double

# Tests: an explicit '-> float64' annotation produces the same IR as the
# default (no annotation). The annotation must be accepted and not alter
# the generated signature.

extern def printd(x: float64) -> float64

def scale(x: float64) -> float64:
    return x * 10

def main() -> None:
    printd(scale(1.5))
    return
