# RUN: not %pyxc %s 2>&1 | FileCheck %s
# CHECK: Unknown variable name
# CHECK-NOT: ready>

# Tests: globals must be declared before use in initializers.

extern def printd(x: float64) -> float64

var b: float64 = a * 2   # a is not yet initialized — reads 0.0, so: float64 b = 0.0
var a: float64 = 5.0
printd(b)
