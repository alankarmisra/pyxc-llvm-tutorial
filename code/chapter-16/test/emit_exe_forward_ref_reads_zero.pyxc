# RUN: not %pyxc --emit exe -o %t %s 2>&1 | FileCheck %s
# CHECK: Unknown variable name

# Tests: globals must be declared before use in initializers.

extern def printd(x: float64) -> float64

var early: float64 = late   # late has not been initialized yet — reads 0.0
var late: float64 = 10.0

def main() -> None:
    printd(early)
    printd(late)
