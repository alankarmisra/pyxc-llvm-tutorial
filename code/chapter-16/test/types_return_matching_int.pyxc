# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 12.000000

# Tests: an int function correctly returns an int computed by arithmetic.
# 3 * 4 = 12. Integration: correct computation, correct return, correct cast.

extern def printd(x: float64) -> float64

def mul(a: int, b: int) -> int:
    return a * b

def main() -> None:
    printd(float64(mul(3, 4)))
    return
