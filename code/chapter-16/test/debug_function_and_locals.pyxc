# REQUIRES: llvm-dwarfdump
# RUN: %pyxc -g --emit obj -o %t.o %s
# RUN: %dwarfdump --debug-info %t.o | FileCheck %s
# CHECK: DW_TAG_subprogram
# CHECK: DW_TAG_formal_parameter
# CHECK: DW_TAG_variable

# Tests: -g emits function, parameter, and local variable debug metadata.

extern def printd(x: float64) -> float64

def add(a: float64, b: float64) -> float64:
    var s: float64 = a
    s = s + b
    return s

def main() -> None:
    printd(add(1, 2))
