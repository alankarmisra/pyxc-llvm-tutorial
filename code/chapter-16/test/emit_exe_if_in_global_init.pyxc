# RUN: %pyxc --emit exe -o %t %s
# RUN: %t 2>&1 | FileCheck %s
# CHECK: 99.000000

# Tests: a top-level if statement executes inside __pyxc.global_init before main().

extern def printd(x: float64) -> float64

var result: float64 = 0.0
var flag: bool = True

if flag:
    result = 99

def main() -> None:
    printd(result)
