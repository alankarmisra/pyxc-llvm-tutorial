# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 0.000000
# CHECK-NOT: ready>

# Tests: a global initializer that references a global declared later reads 0.0
# (the constant default), not the later global's initialized value.
# Initializers run in source order; b is initialized before a, so a is still 0.0
# when b's initializer runs.

extern def printd(x)

var b = a * 2   # a is not yet initialized — reads 0.0, so b = 0.0
var a = 5
printd(b)
