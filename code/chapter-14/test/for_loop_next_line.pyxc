# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK: 2.000000


# Tests: for loop body on the next line after ':'.
# forstmt = "for" identifier "=" expression "," expression "," expression ":" suite ;

extern def printd(x)

def run():
    for var i = 1, i < 3, 1:
        printd(i)

run()
