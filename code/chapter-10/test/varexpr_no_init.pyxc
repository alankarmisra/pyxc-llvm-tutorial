# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Evaluated to 0.000000

# Tests: var without an initializer defaults to 0.0.
# varbinding = identifier [ "=" expression ] ;
#
# When no "=" follows the identifier, ParseVarExpr inserts NumberExprAST(0.0)
# as the initializer. The body "x" loads that 0.0 slot.

var x: x
