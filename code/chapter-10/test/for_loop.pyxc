# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed an extern.
# CHECK: Parsed a function definition.
# CHECK: 1.000000
# CHECK: 2.000000
# CHECK: 3.000000


# Tests: for loop executes its body once per iteration.
# forexpr = "for" identifier "=" expression "," expression "," expression ":" [ eols ] expression
#
# count(3) runs: i=1 (printd(1)), i=2 (printd(2)), i=3 (printd(3)), i=4 (4<=3 false, stop).
# The for expression itself returns 0.0.

extern def printd(x)

def count(n): return for var i = 1, i <= n, 1: printd(i)

count(3)
