# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Expected ':' after var bindings

# Tests: "var" without the mandatory ":" before the body is a parse error.
# ParseVarExpr requires CurTok == ':' after all bindings are consumed.
