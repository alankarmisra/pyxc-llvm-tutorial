# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed a user-defined operator.
# CHECK: Parsed a function definition.
# CHECK: Evaluated to -1.000000


# unaryminus applied to a user-defined unary op: -!x
# ! is logical not: returns 1 for zero, 0 for non-zero.

@unary
def !(x): return if x == 0: 1 else: 0

def test(x): return -!x

# -!0 == -(1) == -1
test(0)
