# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed a function definition.
# CHECK: Evaluated to 10.000000


# Tests: inline if/else (condition, then, and else all on one line).
# conditionalexpr = "if" expression ":" [ eols ] expression [ eols ] "else" ":" [ eols ] expression

def maxval(a, b): return if a > b: a else: b

maxval(10, 5)
