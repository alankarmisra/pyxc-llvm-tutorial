# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 99.000000
# CHECK: 1.000000
# CHECK-NOT: ready>

# Tests: a local var inside a function shadows a global of the same name
# without affecting the global. After f() returns, the global x is still 1.

extern def printd(x)

var x = 1

def f():
    var x = 99
    return x

printd(f())
printd(x)
