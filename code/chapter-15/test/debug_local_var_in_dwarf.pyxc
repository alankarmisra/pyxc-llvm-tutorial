# REQUIRES: llvm-dwarfdump
# RUN: %pyxc -g --emit obj -o %t.o %s
# RUN: %dwarfdump %t.o | FileCheck %s
# CHECK: DW_TAG_variable
# CHECK: DW_AT_name{{.*}}"accumulator"

# Tests: a 'var' declared inside a function body appears in DWARF as a
# DW_TAG_variable with the correct DW_AT_name. This is distinct from
# DW_TAG_formal_parameter (which is for parameters).

extern def printd(x)

def sum_to(n):
    var accumulator = 0
    for var i = 1, i < n + 1, 1:
        accumulator = accumulator + i
    return accumulator

def main():
    printd(sum_to(5))
