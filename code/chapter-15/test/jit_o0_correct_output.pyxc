# RUN: %pyxc -O0 %s 2>&1 | FileCheck %s
# CHECK: 55.000000

# Tests: -O0 in JIT file-run mode produces correct output. Optimization level
# affects IR quality but must not change observable program behaviour.

extern def printd(x)

var sum = 0

def accumulate(n):
    sum = sum + n

def main():
    for var i = 1, i < 11, 1:
        accumulate(i)
    printd(sum)
