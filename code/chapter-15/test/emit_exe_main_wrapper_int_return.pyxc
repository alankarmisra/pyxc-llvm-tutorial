# RUN: %pyxc --emit exe -o %t %s
# RUN: %t; echo "exit:$?" | FileCheck %s
# CHECK: exit:0

# Tests: the synthesised int main() wrapper always returns 0 to the OS,
# regardless of the double value that the user's main() returns.
# Even though user main() returns 42.0, the process exit code is 0.

def main():
    return 42
