# REQUIRES: llvm-dwarfdump
# RUN: %pyxc -g --emit obj -o %t.o %s
# RUN: %dwarfdump %t.o | FileCheck %s
# CHECK: DW_TAG_subprogram
# CHECK: DW_AT_name{{.*}}"fib"
# CHECK: DW_TAG_subprogram
# CHECK: DW_AT_name{{.*}}"fac"
# CHECK: DW_TAG_subprogram
# CHECK: DW_AT_name{{.*}}"main"

# Tests: three functions all produce DW_TAG_subprogram entries. Verifies that
# the debug info generation loop handles multiple functions correctly, not just
# the first or last one.

extern def printd(x)

def fib(n):
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

def fac(n):
    if n < 2:
        return 1
    return n * fac(n - 1)

def main():
    printd(fib(7))
    printd(fac(5))
