# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 7.000000
# CHECK-NOT: ready>


# Tests: file input mode — when a filename is passed as a positional argument,
# pyxc runs the file instead of starting the REPL. No 'ready>' prompts appear
# and 'Parsed ...' log messages are suppressed (Log() is silent in file mode).
# The evaluator produces no output in file mode; program output requires
# explicit print calls. Pass -v to see the IR dump.

extern def printd(x)

def add(a, b): return a + b

printd(add(3, 4))
