# RUN: %pyxc -O2 --emit llvm-ir -o %t.ll %s
# RUN: FileCheck --input-file=%t.ll %s
# CHECK: ret double 9.000000e+00
# CHECK-NOT: fadd double
# CHECK-NOT: fmul double

# Tests: at -O2 without -g, constant expressions are fully folded. The function
# body reduces to a single constant return with no arithmetic instructions.
# Compare with g_and_o2_keeps_opt.pyxc which uses -g -O2.

def main():
    return (1 + 2) * 3
