# RUN: %pyxc %s 2>&1 | FileCheck %s
# CHECK: 1.000000
# CHECK-NOT: ready>

# Tests: a variable declared inside an if block is not visible after the block.
# The outer var x = 1 is unchanged after the inner block exits.

extern def printd(x)

def f():
    var x = 1
    if x > 0:
        var x = 99
    return x

printd(f())
