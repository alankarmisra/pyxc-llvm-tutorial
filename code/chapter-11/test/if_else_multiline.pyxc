# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed a function definition.
# CHECK: Evaluated to 5.000000


# Tests: if/else with then and else blocks on separate lines.
# ifstmt = "if" expression ":" suite [ eols "else" ":" suite ] ;

def minval(a, b):
    if a < b:
        return a
    else:
        return b

minval(5, 10)
