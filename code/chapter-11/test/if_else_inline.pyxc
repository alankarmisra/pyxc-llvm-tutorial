# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Parsed a function definition.
# CHECK: Evaluated to 10.000000


# Tests: inline if/else statement with both branches on one line.
# ifstmt = "if" expression ":" suite [ eols "else" ":" suite ]

def maxval(a, b):
    if a > b: return a else: return b

maxval(10, 5)
