# RUN: %pyxc < %s 2>&1 | FileCheck %s
# CHECK: Destination of '=' must be a variable

# Tests: the left-hand side of "=" in a simple statement must be a plain
# variable name; a parenthesised expression is rejected.
# ParseSimpleStmt calls Expr->getVariableName() after seeing "="; a
# parenthesised expression returns nullptr and triggers this error.
# simplestmt = returnstmt | varstmt | assignstmt | expression ;

(1 + 2) = 3
